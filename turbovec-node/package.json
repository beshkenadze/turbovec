{
  "name": "@beshkenadze/turbovec",
  "version": "0.1.0",
  "description": "Fast vector quantization with 2-4 bit compression and SIMD search — native Node bindings",
  "license": "MIT",
  "author": "Ryan Codrai",
  "homepage": "https://github.com/beshkenadze/turbovec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beshkenadze/turbovec.git"
  },
  "bugs": {
    "url": "https://github.com/beshkenadze/turbovec/issues"
  },
  "keywords": [
    "vector-search",
    "quantization",
    "nearest-neighbor",
    "ann",
    "simd",
    "rag",
    "embeddings"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "napi": {
    "binaryName": "turbovec",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node examples/smoke.mjs",
    "create-npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish --no-gh-release -t npm",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  }
}
